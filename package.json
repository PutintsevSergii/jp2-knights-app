{
  "name": "jp2-knights-app",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the JP2 Knights app digital ecosystem.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @jp2/api dev",
    "dev:admin": "pnpm --filter @jp2/admin dev",
    "dev:mobile": "pnpm --filter @jp2/mobile dev",
    "dev:admin:demo": "APP_RUNTIME_MODE=demo pnpm --filter @jp2/admin dev",
    "dev:mobile:demo": "APP_RUNTIME_MODE=demo pnpm --filter @jp2/mobile dev",
    "lint": "nx run-many -t lint --all",
    "typecheck": "nx run-many -t typecheck --all",
    "test": "nx run-many -t test --all",
    "test:coverage": "vitest run --coverage",
    "build": "nx run-many -t build --all",
    "contract:generate": "node tools/scripts/contract-generate.mjs",
    "contract:check": "node tools/scripts/contract-check.mjs",
    "prisma:generate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jp2_app prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jp2_app prisma validate --schema prisma/schema.prisma",
    "db:seed": "node prisma/seed.mjs",
    "db:migrate:check": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jp2_app prisma validate --schema prisma/schema.prisma && node tools/scripts/db-migrate-check.mjs",
    "quality": "pnpm prisma:generate && pnpm lint && pnpm typecheck && pnpm test && pnpm test:coverage && pnpm build && pnpm contract:generate && pnpm contract:check && pnpm db:migrate:check"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/testing": "11.1.19",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "nx": "22.7.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "prisma": "6.19.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/swagger": "11.4.2",
    "@prisma/client": "6.19.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.1"
  }
}
