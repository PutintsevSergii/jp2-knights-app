                        },
                        "preferredLanguage": {
                          "type": "string",
                          "nullable": true
                        },
                        "status": {
                          "type": "string",
                          "enum": [
                            "active",
                            "inactive",
                            "invited",
                            "archived"
                          ]
                        },
                        "roles": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "CANDIDATE",
                              "BROTHER",
                              "OFFICER",
                              "SUPER_ADMIN"
                            ]
                          }
                        }
                      }
                    },
                    "access": {
                      "type": "object",
                      "required": [
                        "mobileMode",
                        "adminLite"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "mobileMode": {
                          "type": "string",
                          "enum": [
                            "public",
                            "candidate",
                            "brother"
                          ]
                        },
                        "adminLite": {
                          "type": "boolean"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No active authenticated user is available.",
