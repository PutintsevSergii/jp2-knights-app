                    "app",
                    "runtimeMode",
                    "status"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "app": {
                      "type": "string",
                      "enum": [
                        "api"
                      ]
                    },
                    "runtimeMode": {
                      "type": "string",
                      "enum": [
                        "api",
                        "demo",
                        "test"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "CurrentUserController_getCurrentUser",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Current authenticated user identity, roles, and resolved app access.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "user",
                    "access"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "user": {
                      "type": "object",
