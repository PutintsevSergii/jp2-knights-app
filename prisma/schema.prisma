generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  invited
  archived
}

enum Role {
  CANDIDATE
  BROTHER
  OFFICER
  SUPER_ADMIN
}

enum OrganizationUnitType {
  ORDER
  PROVINCE
  COMMANDERY
  CHORAGIEW
  OTHER
}

enum OrganizationUnitStatus {
  active
  archived
}

enum MembershipStatus {
  active
  inactive
  archived
}

enum Visibility {
  PUBLIC
  FAMILY_OPEN
  CANDIDATE
  BROTHER
  ORGANIZATION_UNIT
  OFFICER
  ADMIN

  @@map("visibility")
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED

  @@map("content_status")
}

enum EventStatus {
  draft
  published
  cancelled
  archived

  @@map("event_status")
}

enum CandidateRequestStatus {
  new
  contacted
  invited
  rejected
  converted_to_candidate

  @@map("candidate_request_status")
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @db.Citext
  phone             String?
  displayName       String     @map("display_name")
  status            UserStatus @default(invited)
  preferredLanguage String?    @map("preferred_language")
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt        DateTime?  @map("archived_at") @db.Timestamptz(6)

  roles                    UserRole[]                @relation("UserRoles")
  rolesCreated             UserRole[]                @relation("RoleCreator")
  memberships              Membership[]
  officerAssignments       OfficerAssignment[]       @relation("OfficerUser")
  officerAssignmentsMade   OfficerAssignment[]       @relation("OfficerAssignmentCreator")
  auditLogs                AuditLog[]                @relation("AuditActor")
  identityProviderAccounts IdentityProviderAccount[]

  @@index([status])
  @@map("users")
}

model IdentityProviderAccount {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String
  providerSubject String    @map("provider_subject")
  email           String?   @db.Citext
  emailVerified   Boolean?  @map("email_verified")
  phone           String?
  displayName     String?   @map("display_name")
  photoUrl        String?   @map("photo_url")
  lastSignInAt    DateTime? @map("last_sign_in_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([provider, providerSubject])
  @@index([revokedAt])
  @@map("identity_provider_accounts")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      Role
  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  user    User  @relation("UserRoles", fields: [userId], references: [id], onDelete: Restrict)
  creator User? @relation("RoleCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

model OrganizationUnit {
  id                String                 @id @default(uuid()) @db.Uuid
  type              OrganizationUnitType   @default(CHORAGIEW)
  parentUnitId      String?                @map("parent_unit_id") @db.Uuid
  name              String
  city              String
  country           String
  parish            String?
  status            OrganizationUnitStatus @default(active)
  publicDescription String?                @map("public_description")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt        DateTime?              @map("archived_at") @db.Timestamptz(6)

  parent             OrganizationUnit?   @relation("OrganizationUnitHierarchy", fields: [parentUnitId], references: [id], onDelete: Restrict)
  children           OrganizationUnit[]  @relation("OrganizationUnitHierarchy")
  memberships        Membership[]
  officerAssignments OfficerAssignment[]
  candidateRequests  CandidateRequest[]

  @@index([parentUnitId])
  @@index([type, status])
  @@index([status])
  @@map("organization_units")
}

model Membership {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  organizationUnitId String           @map("organization_unit_id") @db.Uuid
  status             MembershipStatus @default(active)
  currentDegree      String?          @map("current_degree")
  joinedAt           DateTime?        @map("joined_at") @db.Date
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt         DateTime?        @map("archived_at") @db.Timestamptz(6)

  user             User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)

  @@index([organizationUnitId, status])
  @@index([userId])
  @@map("memberships")
}

model OfficerAssignment {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  organizationUnitId String    @map("organization_unit_id") @db.Uuid
  title              String?
  startsAt           DateTime  @map("starts_at") @db.Date
  endsAt             DateTime? @map("ends_at") @db.Date
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user             User             @relation("OfficerUser", fields: [userId], references: [id], onDelete: Restrict)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)
  creator          User?            @relation("OfficerAssignmentCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationUnitId])
  @@map("officer_assignments")
}

model AuditLog {
  id                      String   @id @default(uuid()) @db.Uuid
  actorUserId             String?  @map("actor_user_id") @db.Uuid
  action                  String
  entityType              String   @map("entity_type")
  entityId                String   @map("entity_id") @db.Uuid
  scopeOrganizationUnitId String?  @map("scope_organization_unit_id") @db.Uuid
  beforeSummary           Json?    @map("before_summary")
  afterSummary            Json?    @map("after_summary")
  requestId               String?  @map("request_id")
  ipAddress               String?  @map("ip_address") @db.Inet
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([scopeOrganizationUnitId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ContentPage {
  id                       String        @id @default(uuid()) @db.Uuid
  slug                     String
  title                    String
  body                     String
  language                 String
  visibility               Visibility
  targetOrganizationUnitId String?       @map("target_organization_unit_id") @db.Uuid
  status                   ContentStatus
  createdBy                String?       @map("created_by") @db.Uuid
  updatedBy                String?       @map("updated_by") @db.Uuid
  approvedBy               String?       @map("approved_by") @db.Uuid
  publishedBy              String?       @map("published_by") @db.Uuid
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt              DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt               DateTime?     @map("archived_at") @db.Timestamptz(6)

  @@unique([slug, language])
  @@index([visibility, status, language])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("content_pages")
}

model PrayerCategory {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String
  title       String
  language    String
  sortOrder   Int           @default(0) @map("sort_order")
  status      ContentStatus
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(6)

  prayers Prayer[]

  @@unique([slug, language])
  @@index([status, language, sortOrder])
  @@map("prayer_categories")
}

model Prayer {
  id                       String        @id @default(uuid()) @db.Uuid
  categoryId               String?       @map("category_id") @db.Uuid
  title                    String
  body                     String
  language                 String
  visibility               Visibility
  targetOrganizationUnitId String?       @map("target_organization_unit_id") @db.Uuid
  status                   ContentStatus
  createdBy                String?       @map("created_by") @db.Uuid
  updatedBy                String?       @map("updated_by") @db.Uuid
  approvedBy               String?       @map("approved_by") @db.Uuid
  publishedBy              String?       @map("published_by") @db.Uuid
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt              DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt               DateTime?     @map("archived_at") @db.Timestamptz(6)

  category PrayerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([visibility, status, language])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("prayers")
}

model Event {
  id                       String      @id @default(uuid()) @db.Uuid
  title                    String
  description              String?
  type                     String
  startAt                  DateTime    @map("start_at") @db.Timestamptz(6)
  endAt                    DateTime?   @map("end_at") @db.Timestamptz(6)
  locationLabel            String?     @map("location_label")
  visibility               Visibility
  targetOrganizationUnitId String?     @map("target_organization_unit_id") @db.Uuid
  status                   EventStatus
  createdBy                String?     @map("created_by") @db.Uuid
  updatedBy                String?     @map("updated_by") @db.Uuid
  publishedBy              String?     @map("published_by") @db.Uuid
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt              DateTime?   @map("published_at") @db.Timestamptz(6)
  cancelledAt              DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  archivedAt               DateTime?   @map("archived_at") @db.Timestamptz(6)

  @@index([visibility, status, startAt])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("events")
}

model CandidateRequest {
  id                         String                 @id @default(uuid()) @db.Uuid
  firstName                  String                 @map("first_name")
  lastName                   String                 @map("last_name")
  email                      String                 @db.Citext
  phone                      String?
  country                    String
  city                       String
  preferredLanguage          String?                @map("preferred_language")
  message                    String?
  consentTextVersion         String                 @map("consent_text_version")
  consentAt                  DateTime               @map("consent_at") @db.Timestamptz(6)
  idempotencyKey             String?                @map("idempotency_key")
  status                     CandidateRequestStatus @default(new)
  assignedOrganizationUnitId String?                @map("assigned_organization_unit_id") @db.Uuid
  officerNote                String?                @map("officer_note")
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt                 DateTime?              @map("archived_at") @db.Timestamptz(6)

  assignedOrganizationUnit OrganizationUnit? @relation(fields: [assignedOrganizationUnitId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedOrganizationUnitId])
  @@index([email])
  @@index([idempotencyKey])
  @@map("candidate_requests")
}
