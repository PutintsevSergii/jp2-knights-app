generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  invited
  archived
}

enum Role {
  CANDIDATE
  BROTHER
  OFFICER
  SUPER_ADMIN
}

enum OrganizationUnitType {
  ORDER
  PROVINCE
  COMMANDERY
  CHORAGIEW
  OTHER
}

enum OrganizationUnitStatus {
  active
  archived
}

enum MembershipStatus {
  active
  inactive
  archived
}

enum Visibility {
  PUBLIC
  FAMILY_OPEN
  CANDIDATE
  BROTHER
  ORGANIZATION_UNIT
  OFFICER
  ADMIN

  @@map("visibility")
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED

  @@map("content_status")
}

enum EventStatus {
  draft
  published
  cancelled
  archived

  @@map("event_status")
}

enum CandidateRequestStatus {
  new
  contacted
  invited
  rejected
  converted_to_candidate

  @@map("candidate_request_status")
}

enum CandidateProfileStatus {
  active
  paused
  converted_to_brother
  archived

  @@map("candidate_profile_status")
}

enum IdentityAccessReviewStatus {
  pending
  confirmed
  rejected
  expired

  @@map("identity_access_review_status")
}

enum ParticipationStatus {
  planning_to_attend
  cancelled

  @@map("participation_status")
}

enum DeviceTokenPlatform {
  ios
  android
  web

  @@map("device_token_platform")
}

enum NotificationCategory {
  events
  announcements
  roadmap_updates
  prayer_reminders

  @@map("notification_category")
}

enum RoadmapAssignmentStatus {
  active
  completed
  archived

  @@map("roadmap_assignment_status")
}

enum RoadmapSubmissionStatus {
  pending_review
  approved
  rejected

  @@map("roadmap_submission_status")
}

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String     @db.Citext
  phone             String?
  displayName       String     @map("display_name")
  status            UserStatus @default(invited)
  preferredLanguage String?    @map("preferred_language")
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt        DateTime?  @map("archived_at") @db.Timestamptz(6)

  roles                     UserRole[]                         @relation("UserRoles")
  rolesCreated              UserRole[]                         @relation("RoleCreator")
  memberships               Membership[]
  officerAssignments        OfficerAssignment[]                @relation("OfficerUser")
  officerAssignmentsMade    OfficerAssignment[]                @relation("OfficerAssignmentCreator")
  candidateProfiles         CandidateProfile[]                 @relation("CandidateProfileUser")
  responsibleCandidates     CandidateProfile[]                 @relation("ResponsibleOfficer")
  auditLogs                 AuditLog[]                         @relation("AuditActor")
  eventParticipations       EventParticipation[]
  identityProviderAccounts  IdentityProviderAccount[]
  identityAccessReviews     IdentityAccessReview[]             @relation("IdentityAccessReviewUser")
  identityAccessDecisions   IdentityAccessReview[]             @relation("IdentityAccessReviewDecisionActor")
  accessApproverPrivileges  IdentityAccessApproverAssignment[] @relation("IdentityAccessApproverUser")
  accessApproverGrants      IdentityAccessApproverAssignment[] @relation("IdentityAccessApproverCreator")
  deviceTokens              DeviceToken[]
  notificationPreferences   NotificationPreference[]
  roadmapAssignments        RoadmapAssignment[]                @relation("RoadmapAssignmentUser")
  roadmapAssignmentsCreated RoadmapAssignment[]                @relation("RoadmapAssignmentCreator")
  roadmapSubmissions        RoadmapSubmission[]                @relation("RoadmapSubmissionUser")
  roadmapReviews            RoadmapSubmission[]                @relation("RoadmapSubmissionReviewer")

  @@index([status])
  @@map("users")
}

model DeviceToken {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  platform   DeviceTokenPlatform
  tokenHash  String              @unique @map("token_hash")
  tokenLast4 String              @map("token_last4")
  lastSeenAt DateTime            @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt  DateTime?           @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@index([platform])
  @@map("device_tokens")
}

model NotificationPreference {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  category  NotificationCategory
  enabled   Boolean              @default(true)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, category])
  @@index([category, enabled])
  @@map("notification_preferences")
}

model IdentityProviderAccount {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  provider        String
  providerSubject String    @map("provider_subject")
  email           String?   @db.Citext
  emailVerified   Boolean?  @map("email_verified")
  phone           String?
  displayName     String?   @map("display_name")
  photoUrl        String?   @map("photo_url")
  lastSignInAt    DateTime? @map("last_sign_in_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)

  user          User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  accessReviews IdentityAccessReview[]

  @@index([userId])
  @@index([provider, providerSubject])
  @@index([revokedAt])
  @@map("identity_provider_accounts")
}

model IdentityAccessReview {
  id                      String                     @id @default(uuid()) @db.Uuid
  userId                  String                     @map("user_id") @db.Uuid
  providerAccountId       String                     @map("provider_account_id") @db.Uuid
  status                  IdentityAccessReviewStatus @default(pending)
  scopeOrganizationUnitId String?                    @map("scope_organization_unit_id") @db.Uuid
  requestedRole           Role?                      @map("requested_role")
  assignedRole            Role?                      @map("assigned_role")
  expiresAt               DateTime                   @map("expires_at") @db.Timestamptz(6)
  decidedBy               String?                    @map("decided_by") @db.Uuid
  decidedAt               DateTime?                  @map("decided_at") @db.Timestamptz(6)
  decisionNote            String?                    @map("decision_note")
  createdAt               DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  user            User                    @relation("IdentityAccessReviewUser", fields: [userId], references: [id], onDelete: Restrict)
  providerAccount IdentityProviderAccount @relation(fields: [providerAccountId], references: [id], onDelete: Restrict)
  scopeUnit       OrganizationUnit?       @relation("IdentityAccessReviewScope", fields: [scopeOrganizationUnitId], references: [id], onDelete: SetNull)
  decisionActor   User?                   @relation("IdentityAccessReviewDecisionActor", fields: [decidedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([providerAccountId])
  @@index([status, expiresAt])
  @@index([scopeOrganizationUnitId, status])
  @@map("identity_access_reviews")
}

model IdentityAccessApproverAssignment {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  organizationUnitId String    @map("organization_unit_id") @db.Uuid
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt          DateTime? @map("revoked_at") @db.Timestamptz(6)

  user             User             @relation("IdentityAccessApproverUser", fields: [userId], references: [id], onDelete: Restrict)
  organizationUnit OrganizationUnit @relation("IdentityAccessApproverScope", fields: [organizationUnitId], references: [id], onDelete: Restrict)
  creator          User?            @relation("IdentityAccessApproverCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationUnitId])
  @@index([revokedAt])
  @@map("identity_access_approver_assignments")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      Role
  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  user    User  @relation("UserRoles", fields: [userId], references: [id], onDelete: Restrict)
  creator User? @relation("RoleCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

model OrganizationUnit {
  id                String                 @id @default(uuid()) @db.Uuid
  type              OrganizationUnitType   @default(CHORAGIEW)
  parentUnitId      String?                @map("parent_unit_id") @db.Uuid
  name              String
  city              String
  country           String
  parish            String?
  status            OrganizationUnitStatus @default(active)
  publicDescription String?                @map("public_description")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt        DateTime?              @map("archived_at") @db.Timestamptz(6)

  parent                  OrganizationUnit?                  @relation("OrganizationUnitHierarchy", fields: [parentUnitId], references: [id], onDelete: Restrict)
  children                OrganizationUnit[]                 @relation("OrganizationUnitHierarchy")
  memberships             Membership[]
  officerAssignments      OfficerAssignment[]
  candidateRequests       CandidateRequest[]
  candidateProfiles       CandidateProfile[]
  identityAccessReviews   IdentityAccessReview[]             @relation("IdentityAccessReviewScope")
  identityAccessApprovers IdentityAccessApproverAssignment[] @relation("IdentityAccessApproverScope")
  announcements           Announcement[]
  roadmapAssignments      RoadmapAssignment[]

  @@index([parentUnitId])
  @@index([type, status])
  @@index([status])
  @@map("organization_units")
}

model Membership {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  organizationUnitId String           @map("organization_unit_id") @db.Uuid
  status             MembershipStatus @default(active)
  currentDegree      String?          @map("current_degree")
  joinedAt           DateTime?        @map("joined_at") @db.Date
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt         DateTime?        @map("archived_at") @db.Timestamptz(6)

  user             User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)

  @@index([organizationUnitId, status])
  @@index([userId])
  @@map("memberships")
}

model OfficerAssignment {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  organizationUnitId String    @map("organization_unit_id") @db.Uuid
  title              String?
  startsAt           DateTime  @map("starts_at") @db.Date
  endsAt             DateTime? @map("ends_at") @db.Date
  createdBy          String?   @map("created_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user             User             @relation("OfficerUser", fields: [userId], references: [id], onDelete: Restrict)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId], references: [id], onDelete: Restrict)
  creator          User?            @relation("OfficerAssignmentCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationUnitId])
  @@map("officer_assignments")
}

model AuditLog {
  id                      String   @id @default(uuid()) @db.Uuid
  actorUserId             String?  @map("actor_user_id") @db.Uuid
  action                  String
  entityType              String   @map("entity_type")
  entityId                String   @map("entity_id") @db.Uuid
  scopeOrganizationUnitId String?  @map("scope_organization_unit_id") @db.Uuid
  beforeSummary           Json?    @map("before_summary")
  afterSummary            Json?    @map("after_summary")
  requestId               String?  @map("request_id")
  ipAddress               String?  @map("ip_address") @db.Inet
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([scopeOrganizationUnitId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Announcement {
  id                       String        @id @default(uuid()) @db.Uuid
  title                    String
  body                     String
  visibility               Visibility
  targetOrganizationUnitId String?       @map("target_organization_unit_id") @db.Uuid
  pinned                   Boolean       @default(false)
  status                   ContentStatus
  createdBy                String?       @map("created_by") @db.Uuid
  updatedBy                String?       @map("updated_by") @db.Uuid
  approvedBy               String?       @map("approved_by") @db.Uuid
  publishedBy              String?       @map("published_by") @db.Uuid
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt              DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt               DateTime?     @map("archived_at") @db.Timestamptz(6)

  targetOrganizationUnit OrganizationUnit? @relation(fields: [targetOrganizationUnitId], references: [id], onDelete: SetNull)

  @@index([visibility, status, pinned])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("announcements")
}

model ContentPage {
  id                       String        @id @default(uuid()) @db.Uuid
  slug                     String
  title                    String
  body                     String
  language                 String
  visibility               Visibility
  targetOrganizationUnitId String?       @map("target_organization_unit_id") @db.Uuid
  status                   ContentStatus
  createdBy                String?       @map("created_by") @db.Uuid
  updatedBy                String?       @map("updated_by") @db.Uuid
  approvedBy               String?       @map("approved_by") @db.Uuid
  publishedBy              String?       @map("published_by") @db.Uuid
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt              DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt               DateTime?     @map("archived_at") @db.Timestamptz(6)

  @@unique([slug, language])
  @@index([visibility, status, language])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("content_pages")
}

model PrayerCategory {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String
  title       String
  language    String
  sortOrder   Int           @default(0) @map("sort_order")
  status      ContentStatus
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(6)

  prayers Prayer[]

  @@unique([slug, language])
  @@index([status, language, sortOrder])
  @@map("prayer_categories")
}

model Prayer {
  id                       String        @id @default(uuid()) @db.Uuid
  categoryId               String?       @map("category_id") @db.Uuid
  title                    String
  body                     String
  language                 String
  visibility               Visibility
  targetOrganizationUnitId String?       @map("target_organization_unit_id") @db.Uuid
  status                   ContentStatus
  createdBy                String?       @map("created_by") @db.Uuid
  updatedBy                String?       @map("updated_by") @db.Uuid
  approvedBy               String?       @map("approved_by") @db.Uuid
  publishedBy              String?       @map("published_by") @db.Uuid
  createdAt                DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt               DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt              DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt               DateTime?     @map("archived_at") @db.Timestamptz(6)

  category PrayerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([visibility, status, language])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("prayers")
}

model Event {
  id                       String      @id @default(uuid()) @db.Uuid
  title                    String
  description              String?
  type                     String
  startAt                  DateTime    @map("start_at") @db.Timestamptz(6)
  endAt                    DateTime?   @map("end_at") @db.Timestamptz(6)
  locationLabel            String?     @map("location_label")
  visibility               Visibility
  targetOrganizationUnitId String?     @map("target_organization_unit_id") @db.Uuid
  status                   EventStatus
  createdBy                String?     @map("created_by") @db.Uuid
  updatedBy                String?     @map("updated_by") @db.Uuid
  publishedBy              String?     @map("published_by") @db.Uuid
  createdAt                DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt              DateTime?   @map("published_at") @db.Timestamptz(6)
  cancelledAt              DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  archivedAt               DateTime?   @map("archived_at") @db.Timestamptz(6)

  participations EventParticipation[]

  @@index([visibility, status, startAt])
  @@index([status, publishedAt])
  @@index([targetOrganizationUnitId])
  @@map("events")
}

model EventParticipation {
  id           String              @id @default(uuid()) @db.Uuid
  eventId      String              @map("event_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  intentStatus ParticipationStatus @default(planning_to_attend) @map("intent_status")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancelledAt  DateTime?           @map("cancelled_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([eventId])
  @@index([userId])
  @@index([intentStatus])
  @@map("event_participation")
}

model CandidateRequest {
  id                         String                 @id @default(uuid()) @db.Uuid
  firstName                  String                 @map("first_name")
  lastName                   String                 @map("last_name")
  email                      String                 @db.Citext
  phone                      String?
  country                    String
  city                       String
  preferredLanguage          String?                @map("preferred_language")
  message                    String?
  consentTextVersion         String                 @map("consent_text_version")
  consentAt                  DateTime               @map("consent_at") @db.Timestamptz(6)
  idempotencyKey             String?                @map("idempotency_key")
  status                     CandidateRequestStatus @default(new)
  assignedOrganizationUnitId String?                @map("assigned_organization_unit_id") @db.Uuid
  officerNote                String?                @map("officer_note")
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt                 DateTime?              @map("archived_at") @db.Timestamptz(6)

  assignedOrganizationUnit OrganizationUnit?  @relation(fields: [assignedOrganizationUnitId], references: [id], onDelete: SetNull)
  candidateProfiles        CandidateProfile[]

  @@index([status])
  @@index([assignedOrganizationUnitId])
  @@index([email])
  @@index([idempotencyKey])
  @@map("candidate_requests")
}

model CandidateProfile {
  id                         String                 @id @default(uuid()) @db.Uuid
  userId                     String                 @map("user_id") @db.Uuid
  candidateRequestId         String?                @map("candidate_request_id") @db.Uuid
  assignedOrganizationUnitId String?                @map("assigned_organization_unit_id") @db.Uuid
  responsibleOfficerId       String?                @map("responsible_officer_id") @db.Uuid
  status                     CandidateProfileStatus @default(active)
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt                 DateTime?              @map("archived_at") @db.Timestamptz(6)

  user                     User              @relation("CandidateProfileUser", fields: [userId], references: [id], onDelete: Restrict)
  candidateRequest         CandidateRequest? @relation(fields: [candidateRequestId], references: [id], onDelete: SetNull)
  assignedOrganizationUnit OrganizationUnit? @relation(fields: [assignedOrganizationUnitId], references: [id], onDelete: SetNull)
  responsibleOfficer       User?             @relation("ResponsibleOfficer", fields: [responsibleOfficerId], references: [id], onDelete: SetNull)

  @@index([candidateRequestId])
  @@index([assignedOrganizationUnitId, status])
  @@index([responsibleOfficerId])
  @@index([userId])
  @@index([status])
  @@map("candidate_profiles")
}

model RoadmapDefinition {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  targetRole  Role          @map("target_role")
  status      ContentStatus @default(DRAFT)
  language    String
  createdBy   String?       @map("created_by") @db.Uuid
  updatedBy   String?       @map("updated_by") @db.Uuid
  approvedBy  String?       @map("approved_by") @db.Uuid
  publishedBy String?       @map("published_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  approvedAt  DateTime?     @map("approved_at") @db.Timestamptz(6)
  publishedAt DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt  DateTime?     @map("archived_at") @db.Timestamptz(6)

  stages      RoadmapStage[]
  assignments RoadmapAssignment[]

  @@index([targetRole, status])
  @@index([status, publishedAt])
  @@map("roadmap_definitions")
}

model RoadmapStage {
  id                  String    @id @default(uuid()) @db.Uuid
  roadmapDefinitionId String    @map("roadmap_definition_id") @db.Uuid
  title               String
  sortOrder           Int       @map("sort_order")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime? @map("archived_at") @db.Timestamptz(6)

  roadmapDefinition RoadmapDefinition @relation(fields: [roadmapDefinitionId], references: [id], onDelete: Restrict)
  steps             RoadmapStep[]

  @@unique([roadmapDefinitionId, sortOrder])
  @@index([roadmapDefinitionId])
  @@map("roadmap_stages")
}

model RoadmapStep {
  id                 String        @id @default(uuid()) @db.Uuid
  stageId            String        @map("stage_id") @db.Uuid
  title              String
  description        String?
  requiresSubmission Boolean       @default(false) @map("requires_submission")
  sortOrder          Int           @map("sort_order")
  status             ContentStatus @default(DRAFT)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  publishedAt        DateTime?     @map("published_at") @db.Timestamptz(6)
  archivedAt         DateTime?     @map("archived_at") @db.Timestamptz(6)

  stage       RoadmapStage        @relation(fields: [stageId], references: [id], onDelete: Restrict)
  submissions RoadmapSubmission[]

  @@unique([stageId, sortOrder])
  @@index([stageId, status])
  @@map("roadmap_steps")
}

model RoadmapAssignment {
  id                  String                  @id @default(uuid()) @db.Uuid
  userId              String                  @map("user_id") @db.Uuid
  roadmapDefinitionId String                  @map("roadmap_definition_id") @db.Uuid
  organizationUnitId  String?                 @map("organization_unit_id") @db.Uuid
  status              RoadmapAssignmentStatus @default(active)
  assignedBy          String?                 @map("assigned_by") @db.Uuid
  assignedAt          DateTime                @default(now()) @map("assigned_at") @db.Timestamptz(6)
  completedAt         DateTime?               @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime?               @map("archived_at") @db.Timestamptz(6)

  user              User                @relation("RoadmapAssignmentUser", fields: [userId], references: [id], onDelete: Restrict)
  roadmapDefinition RoadmapDefinition   @relation(fields: [roadmapDefinitionId], references: [id], onDelete: Restrict)
  organizationUnit  OrganizationUnit?   @relation(fields: [organizationUnitId], references: [id], onDelete: SetNull)
  assigner          User?               @relation("RoadmapAssignmentCreator", fields: [assignedBy], references: [id], onDelete: SetNull)
  submissions       RoadmapSubmission[]

  @@index([userId, status])
  @@index([roadmapDefinitionId, status])
  @@index([organizationUnitId, status])
  @@map("roadmap_assignments")
}

model RoadmapSubmission {
  id             String                  @id @default(uuid()) @db.Uuid
  assignmentId   String                  @map("assignment_id") @db.Uuid
  stepId         String                  @map("step_id") @db.Uuid
  userId         String                  @map("user_id") @db.Uuid
  body           String
  attachmentMeta Json?                   @map("attachment_meta")
  status         RoadmapSubmissionStatus @default(pending_review)
  reviewedBy     String?                 @map("reviewed_by") @db.Uuid
  reviewComment  String?                 @map("review_comment")
  reviewedAt     DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt     DateTime?               @map("archived_at") @db.Timestamptz(6)

  assignment RoadmapAssignment @relation(fields: [assignmentId], references: [id], onDelete: Restrict)
  step       RoadmapStep       @relation(fields: [stepId], references: [id], onDelete: Restrict)
  user       User              @relation("RoadmapSubmissionUser", fields: [userId], references: [id], onDelete: Restrict)
  reviewer   User?             @relation("RoadmapSubmissionReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([assignmentId])
  @@index([userId, status])
  @@index([stepId, status])
  @@index([reviewedBy])
  @@map("roadmap_submissions")
}
