{
  "name": "admin",
  "sourceRoot": "apps/admin/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "command": "pnpm --filter @jp2/admin dev"
    },
    "dev:http-shell": {
      "command": "pnpm --filter @jp2/admin dev:http-shell"
    },
    "lint": {
      "command": "eslint apps/admin/src --max-warnings=0"
    },
    "typecheck": {
      "command": "tsc -b apps/admin/tsconfig.json"
    },
    "test": {
      "command": "vitest run apps/admin"
    },
    "build": {
      "command": "pnpm --filter @jp2/admin build"
    }
  }
}
