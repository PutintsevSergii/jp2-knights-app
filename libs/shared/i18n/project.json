{
  "name": "shared-i18n",
  "sourceRoot": "libs/shared/i18n/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "command": "eslint libs/shared/i18n/src --max-warnings=0"
    },
    "typecheck": {
      "command": "tsc -b libs/shared/i18n/tsconfig.json"
    },
    "test": {
      "command": "vitest run libs/shared/i18n"
    },
    "build": {
      "command": "tsc -p libs/shared/i18n/tsconfig.json"
    }
  }
}
